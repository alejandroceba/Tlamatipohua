      "id": "42a27665"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import plotly.express as px"
      ],
      "id": "da59cee9",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Primera visualización"
      ],
      "id": "66fc3b3a"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "anos = np.arange(2003,2022+1)\n",
        "for ano in anos:\n",
        "    f = f\"datos/Grado_de_Presion_{ano}.xlsx\"\n",
        "    if ano == 2003:\n",
        "        gp = pd.read_excel(f,usecols=[\"Región Hidrológico-Administrativa\",\"Grado de Presión (%)\"])\n",
        "        gp.columns = [\"RHA\",ano]\n",
        "    else:\n",
        "        gp_ano = pd.read_excel(f,usecols=[\"Grado de Presión (%)\"])\n",
        "        gp_ano.columns = [ano]\n",
        "        gp[ano] = gp_ano[ano]\n",
        "gp[\"RHA\"] = gp[\"RHA\"].str.replace(r\"^\\s*[IVXLCDM]+\\s*[-.]?\\s*\", \"\", regex=True)\n",
        "name_mapping = {\n",
        "    \"Península de Baja California\": \"Península De Baja California\",\n",
        "    'Cuencas Centrales del Norte': 'Cuencas Centrales Del Norte',\n",
        "    \"Península de Yucatán\": \"Península De Yucatán\",\n",
        "    'Aguas del Valle de México': 'Valle de México'\n",
        "}\n",
        "gp['RHA'] = gp['RHA'].replace(name_mapping)\n",
        "gp_largo = pd.melt(gp,id_vars=[\"RHA\"],var_name=\"Año\",value_name=\"Grado de presión (%)\")\n",
        "gp_largo[\"Año\"] = gp_largo[\"Año\"].astype(int)\n",
        "geojson = \"datos/rha2023.json\"\n",
        "fig = px.choropleth(gp_largo,geojson=geojson,locations=\"RHA\",featureidkey=\"properties.rha\",color=\"Grado de presión (%)\",animation_frame=\"Año\",color_continuous_scale=\"Viridis\")\n",
        "fig.update_geos(fitbounds=\"locations\",visible=False)"
      ],
      "id": "926a8437",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "px.line(gp_largo,x=\"Año\",y=\"Grado de presión (%)\",color=\"RHA\")"
      ],
      "id": "0e7661e8",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "anos = np.arange(2005,2023+1)\n",
        "for ano in anos:\n",
        "    f = f\"datos/Agua_Renovable_RHA_{ano}.xlsx\"\n",
        "    if ano == 2005:\n",
        "        arpcrha = pd.read_excel(f,usecols=[\"RHA\",\"Agua Renovable per cápita (m³/habitante/año)\"])\n",
        "        arpcrha.columns = [\"RHA\",ano]\n",
        "    else:\n",
        "        arpcrh_ano = pd.read_excel(f,usecols=[\"Agua Renovable per cápita (m³/habitante/año)\"])\n",
        "        arpcrh_ano.columns = [ano]\n",
        "        arpcrha[ano] = arpcrh_ano[ano]\n",
        "name_mapping = {\n",
        "    \"Península de Baja California\": \"Península De Baja California\",\n",
        "    'Cuencas Centrales del Norte': 'Cuencas Centrales Del Norte',\n",
        "    \"Península de Yucatán\": \"Península De Yucatán\",\n",
        "    'Aguas del Valle de México': 'Valle de México'\n",
        "}\n",
        "arpcrha['RHA'] = arpcrha['RHA'].replace(name_mapping)\n",
        "arpcrha_largo = pd.melt(arpcrha,id_vars=[\"RHA\"],var_name=\"Año\",value_name=\"Agua Renovable per cápita (m³/habitante/año)\")\n",
        "arpcrha_largo[\"Año\"] = arpcrha_largo[\"Año\"].astype(int)\n",
        "geojson = \"datos/rha2023.json\"\n",
        "fig = px.choropleth(arpcrha_largo,geojson=geojson,locations=\"RHA\",featureidkey=\"properties.rha\",color=\"Agua Renovable per cápita (m³/habitante/año)\",animation_frame=\"Año\",color_continuous_scale=\"Viridis\")\n",
        "fig.update_geos(fitbounds=\"locations\",visible=False)"
      ],
      "id": "2a5121f3",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "px.line(arpcrha_largo,x=\"Año\",y=\"Agua Renovable per cápita (m³/habitante/año)\",color=\"RHA\")"
      ],
      "id": "644e77e8",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "anos = np.arange(2017,2021+1)\n",
        "for ano in anos:\n",
        "    f = f\"datos/agua_renovable_estatal{ano}.xlsx\"\n",
        "    if ano == 2017:\n",
        "        arpcedo = pd.read_excel(f,usecols=[\"Entidad Federativa\",\"Agua Renovable per cápita (m³/habitante/año)\"])\n",
        "        arpcedo.columns = [\"Estado\",ano]\n",
        "    else:\n",
        "        arpcedo_ano = pd.read_excel(f,usecols=[\"Agua Renovable per cápita (m³/habitante/año)\"])\n",
        "        arpcedo_ano.columns = [ano]\n",
        "        arpcedo[ano] = arpcedo_ano[ano]\n",
        "\n",
        "name_mapping = {\n",
        "    'Coahuila de Zaragoza': 'Coahuila',\n",
        "    'Veracruz de Ignacio de la Llave': 'Veracruz',\n",
        "}\n",
        "\n",
        "arpcedo['Estado'] = arpcedo['Estado'].replace(name_mapping)\n",
        "arpcedo_largo = pd.melt(arpcedo,id_vars=[\"Estado\"],var_name=\"Año\",value_name=\"Agua Renovable per cápita (m³/habitante/año)\")\n",
        "arpcedo_largo[\"Año\"] = arpcedo_largo[\"Año\"].astype(int)\n",
        "geojson = \"https://raw.githubusercontent.com/angelnmara/geojson/master/mexicoHigh.json\"\n",
        "fig = px.choropleth(arpcedo_largo,geojson=geojson,locations=\"Estado\",featureidkey=\"properties.name\",color=\"Agua Renovable per cápita (m³/habitante/año)\",animation_frame=\"Año\",color_continuous_scale=\"Viridis\")\n",
        "fig.update_geos(fitbounds=\"locations\",visible=False)"
      ],
      "id": "1bc940fe",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "px.line(arpcedo_largo,x=\"Año\",y=\"Agua Renovable per cápita (m³/habitante/año)\",color=\"Estado\")"
      ],
